# Backend Environment Variables
# Copy this file to `.env.local` for local development and fill in your values.
# Production (Vercel) should use dashboard/project environment variables instead
# of repo env files.

# Database URL (required)
# Supabase (recommended for production): use the pooled connection string in Vercel/runtime
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
# Existing SQLite file (for one-time data export only): backend/prisma/dev.db
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres
# Direct Postgres URL (recommended for Prisma db push/migrations with Supabase)
DIRECT_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# Privy Configuration (required)
# Get these from your Privy dashboard: https://dashboard.privy.io
PRIVY_APP_ID=your-privy-app-id-here
PRIVY_APP_SECRET=your-privy-app-secret-here

# Server Configuration
NODE_ENV=development
PORT=3000

# Backend URL (for CORS and redirects)
# In production, set this to your actual backend URL
BACKEND_URL=https://phew.vibecode.run

# Optional: Debug mode
DEBUG=false

# Optional: Log level (all, errors, slow)
LOG_LEVEL=info

# Cron maintenance auth (recommended in production)
# Used by Vercel Cron to call /api/posts/maintenance/run
CRON_SECRET=replace-with-a-long-random-secret

# Optional: Helius Solana RPC endpoint (wallet holdings enrichment for posts/wincards)
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
HELIUS_RPC_URL=

# Optional: Upstash Redis REST (recommended for production shared rate limiting/cache)
# Example:
# UPSTASH_REDIS_REST_URL=https://<instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Standard Redis URL (Redis Cloud / Redis Labs) for shared rate limiting/cache
# Example:
# REDIS_URL=redis://default:password@host:19523
REDIS_URL=
