# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database URL (required). With provider "sqlite" in schema, only file: URLs are valid.
# SQLite: file:./dev.db
# PostgreSQL: postgresql://user:password@host:5432/dbname (requires changing schema provider)
DATABASE_URL=file:./dev.db

# Privy Configuration (required)
# Get these from your Privy dashboard: https://dashboard.privy.io
PRIVY_APP_ID=your-privy-app-id-here
PRIVY_APP_SECRET=your-privy-app-secret-here

# Server Configuration
NODE_ENV=development
PORT=3000

# Backend URL (for CORS and redirects)
# In production, set this to your actual backend URL
BACKEND_URL=https://phew.vibecode.run

# Optional: Debug mode
DEBUG=false

# Optional: Log level (all, errors, slow)
LOG_LEVEL=info
