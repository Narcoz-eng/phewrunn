# Backend Environment Variables
# Copy this file to `.env.local` for local development and fill in your values.
# Production (Vercel) should use dashboard/project environment variables instead
# of repo env files.

# Database URL (required)
# Supabase (recommended): use URL with sslmode=require
# Example (direct): postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# Example (pooler transaction mode, recommended for Vercel/serverless):
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=10&sslmode=require
# Existing SQLite file (for one-time data export only): backend/prisma/dev.db
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&pool_timeout=10&sslmode=require
# Direct Postgres URL (recommended for Prisma db push/migrations with Supabase)
DIRECT_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require
# Optional Prisma runtime pool tuning (backend/src/prisma.ts)
# For serverless, start with 1 and only increase carefully after measuring pool pressure.
# PRISMA_CONNECTION_LIMIT=1
# PRISMA_POOL_TIMEOUT_SECONDS=10
# PRISMA_SLOW_QUERY_THRESHOLD_MS=800
# PRISMA_QUERY_LATENCY_WARN_MS=800
# PRISMA_LATENCY_SUMMARY_INTERVAL_MS=60000
# PRISMA_LATENCY_SUMMARY_TOP_N=6
# Optional: set to true only if you explicitly want runtime queries to use DIRECT_URL.
# Default runtime behavior now prefers pooled DATABASE_URL for stability.
# PRISMA_PREFER_DIRECT_URL=false
# Production default is off to keep auth/feed latency stable under load.
# POSTS_ENABLE_OPPORTUNISTIC_MAINTENANCE=false
# Keep intelligence prewarm loops off in serverless request handlers.
# Enable only on a dedicated worker / cron target after measuring DB headroom.
# INTELLIGENCE_PRIORITY_LOOP_ENABLED=false
# Schema compatibility guardrails now run by default unless explicitly disabled.
# PRISMA_ENABLE_COMPAT_GUARDRAILS=false
# FEED_MAX_CONCURRENT_REQUESTS=8
# MAINTENANCE_MAX_CONCURRENT_REQUESTS=1
# SETTLEMENT_MAX_CONCURRENT_REQUESTS=1
# SETTLEMENT_RUN_LOCK_TTL_MS=120000

# Privy Configuration (required)
# Get these from your Privy dashboard: https://dashboard.privy.io
PRIVY_APP_ID=your-privy-app-id-here
PRIVY_APP_SECRET=your-privy-app-secret-here
# Recommended: separate signing secret for backend-issued session tokens
AUTH_SESSION_TOKEN_SECRET=replace-with-a-long-random-secret
# Optional: persist compatibility rows in the Better Auth Session table.
# Recommended false for serverless/stateless production; signed session cookies remain the source of truth.
# AUTH_SESSION_DB_PERSISTENCE_ENABLED=false

# Server Configuration
NODE_ENV=development
PORT=3000

# Backend URL (for CORS and redirects)
# In production, set this to your actual backend URL
BACKEND_URL=https://phew.vibecode.run

# Optional: Debug mode
DEBUG=false

# Optional: Log level (all, errors, slow)
LOG_LEVEL=info

# Cron maintenance auth (recommended in production)
# Used by Vercel Cron to call /api/posts/maintenance/run
CRON_SECRET=replace-with-a-long-random-secret

# Optional: Helius Solana RPC endpoint (wallet holdings enrichment for posts/wincards)
# Example: https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
HELIUS_RPC_URL=

# Optional: Solscan Pro API key (token holders, holder count, dev wallet intelligence)
SOLSCAN_API_KEY=

# Optional: Jupiter platform fee settings (integrator fees)
# JUPITER_PLATFORM_FEE_BPS is basis points (e.g., 100 = 1.00%)
# JUPITER_PLATFORM_FEE_ACCOUNT should be the token account that receives platform fees.
JUPITER_PLATFORM_FEE_BPS=100
JUPITER_PLATFORM_FEE_ACCOUNT=Gqxyto95NExADzBbGka8j1Ki9QjKcEgSHPYVrNCJQTC6

# Optional: Upstash Redis REST (recommended for production shared rate limiting/cache)
# Also recommended for cross-instance signed-session revocation on logout.
# Example:
# UPSTASH_REDIS_REST_URL=https://<instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Standard Redis URL (Redis Cloud / Redis Labs) for shared rate limiting/cache
# Example:
# REDIS_URL=redis://default:password@host:19523
REDIS_URL=

# Web Push (VAPID) — required for browser push notifications
# Generate once with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
# VAPID_PUBLIC_KEY goes in vercel.json env (it's public). VAPID_PRIVATE_KEY must be added
# to Vercel dashboard → Project Settings → Environment Variables (never commit the private key).
VAPID_PUBLIC_KEY=<your-vapid-public-key>
VAPID_PRIVATE_KEY=<your-vapid-private-key>
VAPID_EMAIL=mailto:admin@phewrunn.app

# Optional: Sentry error tracking / tracing
# Example:
# SENTRY_DSN=https://<public_key>@o<org>.ingest.sentry.io/<project_id>
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=${VERCEL_GIT_COMMIT_SHA}
# Start low in production and increase after measuring cost/noise.
# SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
