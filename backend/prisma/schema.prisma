generator client {
  provider = "prisma-client-js"
}

// Use PostgreSQL for production (e.g. Supabase). DATABASE_URL should be a postgres:// URI.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model - Better Auth compatible with SocialFi extensions
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // SocialFi specific fields
  walletAddress     String?   @unique
  walletProvider    String?              // 'phantom', 'solflare', 'metamask', 'other'
  walletConnectedAt DateTime?            // When wallet was connected
  username          String?   @unique
  level         Int       @default(0)  // -5 to 10
  xp            Int       @default(0)  // numerical XP for leveling
  bio           String?                // user bio
  role          String    @default("user") // "user" | "admin"
  isAdmin       Boolean   @default(false) // for admin dashboard access
  isBanned      Boolean   @default(false) // banned users cannot post/comment
  isVerified    Boolean   @default(false) // blue checkmark verification
  winRate7d     Float?
  winRate30d    Float?
  avgRoi7d      Float?
  avgRoi30d     Float?
  trustScore    Float?
  reputationTier String?
  firstCallCount Int      @default(0)
  firstCallAvgRoi Float?
  lastTraderMetricsAt DateTime?

  // Update frequency guards
  lastUsernameUpdate DateTime?  // Can only change username once per 7 days
  lastPhotoUpdate    DateTime?  // Can only change photo once per 24 hours

  // Trade fee settings (poster rewards from swap fees)
  tradeFeeRewardsEnabled Boolean @default(true)
  tradeFeeShareBps       Int     @default(50) // 0-50 (max 0.50%)
  tradeFeePayoutAddress  String? // optional Solana payout wallet; falls back to walletAddress

  // Better Auth relations
  sessions      Session[]
  accounts      Account[]

  // SocialFi relations
  posts         Post[]
  followers     Follow[]  @relation("Following") // users following this user
  following     Follow[]  @relation("Followers") // users this user follows
  likes         Like[]
  comments      Comment[]
  reposts       Repost[]
  reactions     Reaction[]
  notifications Notification[] @relation("UserNotifications") // notifications received
  notificationsSent Notification[] @relation("NotificationsFrom") // notifications triggered
  pushSubscriptions PushSubscription[] // browser push subscriptions
  announcements Announcement[] // announcements created by admin
  viewedAnnouncements AnnouncementView[] // track which announcements user has seen
  posterTradeFeeEvents TradeFeeEvent[] @relation("PosterTradeFeeEvents")
  traderTradeFeeEvents TradeFeeEvent[] @relation("TraderTradeFeeEvents")
  reportsFiled       Report[] @relation("ReportsFiled")
  reportsReceived    Report[] @relation("ReportsReceived")
  reportReviews      Report[] @relation("ReportReviews")
  tokenEvents        TokenEvent[]
  tokenFollows       TokenFollow[]
  traderMetricDays   TraderMetricDaily[]
  alertPreference    AlertPreference?

  @@index([createdAt])
  @@index([level, xp])
  @@index([role])
  @@index([isBanned, createdAt])
  @@index([isVerified, createdAt])
  @@index([walletAddress])
  @@index([username])
  @@index([trustScore, createdAt])
  @@index([winRate30d, avgRoi30d])
}

// Better Auth Session model
model Session {
  id            String    @id
  expiresAt     DateTime
  token         String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  ipAddress     String?
  userAgent     String?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Better Auth Account model (for OAuth providers)
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
  @@index([providerId])
}

// Better Auth Verification model (for email verification, password reset)
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

// Follow relationship between users
model Follow {
  id          String   @id @default(cuid())
  followerId  String   // user who follows
  followingId String   // user being followed
  createdAt   DateTime @default(now())

  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId, createdAt])
}

// SocialFi Post model for crypto calls
model Post {
  id              String    @id @default(cuid())
  content         String
  authorId        String
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tokenId         String?

  // Contract Address tracking
  contractAddress String?
  chainType       String?   // 'solana' or 'evm'

  // Token display info
  tokenSymbol     String?   // for display
  tokenName       String?   // for display
  tokenImage      String?   // token logo URL from DexScreener
  dexscreenerUrl  String?   // direct link to dexscreener

  // Market cap tracking
  entryMcap       Float?
  currentMcap     Float?
  mcap1h          Float?    // Market cap snapshot at 1 hour
  mcap6h          Float?    // Market cap snapshot at 6 hours
  lastMcapUpdate  DateTime? // When mcap was last updated
  trackingMode    String?   // 'active' (first hour, update every 30s) or 'settled' (after 1h, update every 5min)

  // Engagement tracking
  viewCount       Int       @default(0)
  confidenceScore Float?
  hotAlphaScore   Float?
  earlyRunnerScore Float?
  highConvictionScore Float?
  timingTier      String?
  firstCallerRank Int?
  roiPeakPct      Float?
  roiCurrentPct   Float?
  threadCount     Int       @default(0)
  reactionCounts  Json?
  trustedTraderCount Int    @default(0)
  entryQualityScore Float?
  bundlePenaltyScore Float?
  sentimentScore  Float?
  lastIntelligenceAt DateTime?

  // Settlement (1H - official settlement)
  settled         Boolean   @default(false)
  settledAt       DateTime?
  isWin           Boolean?

  // Enhanced settlement tracking for 1H/6H leveling system
  isWin1h         Boolean?  // Win status at 1H settlement
  isWin6h         Boolean?  // Win status at 6H settlement
  percentChange1h Float?    // Percent change at 1H settlement
  percentChange6h Float?    // Percent change at 6H settlement
  recoveryEligible Boolean? // True if loss was <30% at 1H (can recover at 6H)
  settled6h       Boolean   @default(false) // Whether 6H settlement has been processed
  levelChange1h   Int?      // Level change applied at 1H
  levelChange6h   Int?      // Level change applied at 6H (recovery bonus or additional penalty)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  likes           Like[]
  comments        Comment[]
  reposts         Repost[]
  reactions       Reaction[]
  notifications   Notification[]
  tradeFeeEvents  TradeFeeEvent[]
  reports         Report[]
  tokenEvents     TokenEvent[]
  token           Token?    @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  // Indexes for efficient queries
  @@index([authorId, settled]) // For user stats queries
  @@index([authorId, settledAt]) // For time-based stats queries
  @@index([settled, settledAt]) // For settlement batch queries
  @@index([createdAt])
  @@index([createdAt, id])
  @@index([createdAt, authorId])
  @@index([authorId, createdAt])
  @@index([contractAddress, createdAt])
  @@index([settled, createdAt])
  @@index([settled, isWin, authorId])
  @@index([trackingMode, lastMcapUpdate])
  @@index([lastMcapUpdate])
  @@index([chainType, contractAddress])
  @@index([settled6h, createdAt])
  @@index([settled, isWin])
  @@index([createdAt, entryMcap])
  @@index([tokenId, createdAt])
  @@index([confidenceScore, createdAt])
  @@index([hotAlphaScore, createdAt])
  @@index([earlyRunnerScore, createdAt])
  @@index([highConvictionScore, createdAt])
}

model AggregateSnapshot {
  key        String   @id
  version    Int      @default(1)
  payload    Json
  capturedAt DateTime @default(now())
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
  @@index([capturedAt])
}

model TradeFeeEvent {
  id                     String   @id @default(cuid())
  postId                 String
  posterUserId           String
  traderUserId           String?
  traderWalletAddress    String
  status                 String   @default("pending") // "pending" | "confirmed" | "rejected"
  tradeSide              String   // "buy" | "sell"
  inputMint              String
  outputMint             String
  inAmountAtomic         String
  outAmountAtomic        String
  platformFeeBps         Int
  platformFeeAmountAtomic String
  feeMint                String
  posterShareBps         Int
  posterShareAmountAtomic String
  posterPayoutAddress    String?
  txSignature            String?
  confirmedAt            DateTime?
  verificationError      String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  poster User  @relation("PosterTradeFeeEvents", fields: [posterUserId], references: [id], onDelete: Cascade)
  trader User? @relation("TraderTradeFeeEvents", fields: [traderUserId], references: [id], onDelete: SetNull)

  @@index([posterUserId, createdAt])
  @@index([postId, createdAt])
  @@index([status, createdAt])
  @@index([txSignature])
  @@index([traderUserId, createdAt])
}

model Report {
  id            String   @id @default(cuid())
  entityType    String   // "post" | "user"
  reason        String
  details       String?
  status        String   @default("open") // "open" | "reviewing" | "resolved" | "dismissed"
  reporterUserId String
  targetUserId  String?
  postId        String?
  reviewedById  String?
  resolvedAt    DateTime?
  reviewerNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reporter   User  @relation("ReportsFiled", fields: [reporterUserId], references: [id], onDelete: Cascade)
  targetUser User? @relation("ReportsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  post       Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReportReviews", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([entityType, status, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([targetUserId, status, createdAt])
  @@index([postId, status, createdAt])
  @@index([reviewedById, createdAt])
}

// Like model for post likes
model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId, createdAt])
}

// Comment model for post comments
model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  postId    String
  parentId  String?
  rootId    String?
  depth     Int      @default(0)
  kind      String?
  replyCount Int     @default(0)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Comment[] @relation("CommentReplies")
  root      Comment? @relation("CommentRoot", fields: [rootId], references: [id], onDelete: SetNull)
  threadReplies Comment[] @relation("CommentRoot")

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentId, createdAt])
  @@index([rootId, createdAt])
}

// Repost model for sharing posts
model Repost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId, createdAt])
}

// Notification model for alerts
model Notification {
  id        String    @id @default(cuid())
  userId    String    // user receiving the notification
  type      String    // 'new_post', 'like', 'comment', 'follow', 'repost', 'settlement', 'win_1h', 'loss_1h', 'win_6h', 'loss_6h', 'level_up', 'achievement'
  message   String    // notification text
  dedupeKey String?   @unique
  read      Boolean   @default(false)
  dismissed Boolean   @default(false) // soft delete - user dismissed but kept for analytics
  clickedAt DateTime? // track when notification was clicked (for analytics)
  readAt    DateTime?
  priority  Int       @default(0)
  entityType String?
  entityId  String?
  reasonCode String?
  payload   Json?

  // Deep linking data
  postId    String?  // link to post if applicable
  fromUserId String? // user who triggered the notification

  createdAt DateTime @default(now())

  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  fromUser  User?    @relation("NotificationsFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, dismissed, createdAt])
  @@index([userId, read, dismissed])
  @@index([userId, read, dismissed, createdAt])
  @@index([userId, type, createdAt])
  @@index([fromUserId, createdAt])
  @@index([postId, createdAt])
  @@index([entityType, entityId, createdAt])
}

model Token {
  id                        String   @id @default(cuid())
  chainType                 String
  address                   String
  symbol                    String?
  name                      String?
  imageUrl                  String?
  dexscreenerUrl            String?
  launchAt                  DateTime?
  pairAddress               String?
  dexId                     String?
  liquidity                 Float?
  volume24h                 Float?
  holderCount               Int?
  largestHolderPct          Float?
  top10HolderPct            Float?
  deployerSupplyPct         Float?
  bundledWalletCount        Int?
  bundledClusterCount       Int?
  estimatedBundledSupplyPct Float?
  bundleRiskLabel           String?
  tokenRiskScore            Float?
  sentimentScore            Float?
  radarScore                Float?
  confidenceScore           Float?
  hotAlphaScore             Float?
  earlyRunnerScore          Float?
  highConvictionScore       Float?
  isEarlyRunner             Boolean  @default(false)
  earlyRunnerReasons        Json?
  lastIntelligenceAt        DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  calls     Post[]
  clusters  TokenBundleCluster[]
  events    TokenEvent[]
  snapshots TokenMetricSnapshot[]
  followers TokenFollow[]

  @@unique([chainType, address])
  @@index([hotAlphaScore, updatedAt])
  @@index([earlyRunnerScore, updatedAt])
  @@index([highConvictionScore, updatedAt])
  @@index([tokenRiskScore, updatedAt])
}

model TokenMetricSnapshot {
  id                        String   @id @default(cuid())
  tokenId                   String
  capturedAt                DateTime @default(now())
  priceUsd                  Float?
  marketCap                 Float?
  liquidity                 Float?
  volume1h                  Float?
  volume24h                 Float?
  holderCount               Int?
  largestHolderPct          Float?
  top10HolderPct            Float?
  bundledWalletCount        Int?
  estimatedBundledSupplyPct Float?
  tokenRiskScore            Float?
  sentimentScore            Float?
  confidenceScore           Float?
  radarScore                Float?

  token Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, capturedAt])
}

model TokenBundleCluster {
  id                 String   @id @default(cuid())
  tokenId            String
  clusterLabel       String
  walletCount        Int
  estimatedSupplyPct Float
  evidenceJson       Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  token Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId, estimatedSupplyPct])
}

model TokenEvent {
  id        String   @id @default(cuid())
  tokenId    String
  eventType  String
  timestamp  DateTime
  marketCap  Float?
  liquidity  Float?
  volume     Float?
  traderId   String?
  postId     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  token  Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  trader User? @relation(fields: [traderId], references: [id], onDelete: SetNull)
  post   Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([tokenId, timestamp])
  @@index([eventType, timestamp])
}

model Reaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

model TokenFollow {
  id        String   @id @default(cuid())
  userId    String
  tokenId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  token Token @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenId])
  @@index([tokenId, createdAt])
}

model AlertPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  minConfidenceScore   Float?   @default(65)
  minLiquidity         Float?
  maxBundleRiskScore   Float?   @default(45)
  timeframeMinutes     Int?     @default(240)
  notifyFollowedTraders Boolean @default(true)
  notifyFollowedTokens  Boolean @default(true)
  notifyEarlyRunners    Boolean @default(true)
  notifyHotAlpha        Boolean @default(true)
  notifyHighConviction  Boolean @default(true)
  notifyBundleChanges   Boolean @default(true)
  notifyConfidenceCross Boolean @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TraderMetricDaily {
  id              String   @id @default(cuid())
  traderId        String
  bucketDate      DateTime
  callsCount      Int
  settledCount    Int
  winRate         Float
  avgRoi          Float
  firstCalls      Int
  firstCallAvgRoi Float?
  trustScore      Float?

  trader User @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@unique([traderId, bucketDate])
  @@index([bucketDate, trustScore])
}

// Announcement model for admin announcements shown in feed
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  isPinned  Boolean  @default(false)
  priority  Int      @default(0)  // for ordering pinned announcements (higher = first)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Author relation (admin who created)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Track which users have viewed this announcement
  views     AnnouncementView[]

  @@index([isPinned, priority, createdAt])
  @@index([authorId, createdAt])
}

// Browser push notification subscriptions (Web Push API)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Many-to-many relation for tracking announcement views
model AnnouncementView {
  id             String   @id @default(cuid())
  userId         String
  announcementId String
  viewedAt       DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([userId, viewedAt])
  @@index([announcementId, viewedAt])
}
