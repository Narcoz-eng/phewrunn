{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "bun run --hot src/index.ts",
    "start": "node_modules/.bin/prisma generate && node ./scripts/prisma-migrate-deploy.mjs && bun run src/index.ts",
    "build": "npx prisma@6 generate",
    "test": "bun test",
    "studio:up": "cloud-studio --port 3001 --hostname 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "db:push": "npx prisma@6 db push",
    "db:migrate": "node ./scripts/prisma-migrate-deploy.mjs",
    "db:generate": "npx prisma@6 generate",
    "studio": "npx prisma@6 studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "6",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@prisma/client": "6",
    "@privy-io/server-auth": "^1.32.5",
    "@solana/web3.js": "^1.98.4",
    "@types/web-push": "^3.6.4",
    "@vibecodeapp/cloud-studio": "^0.2.4",
    "@vibecodeapp/proxy": "^2.0.3",
    "better-auth": "^1.4.14",
    "bs58": "^6.0.0",
    "hono": "^4.6.0",
    "tweetnacl": "^1.0.3",
    "web-push": "^3.6.7",
    "zod": "^4.1.11"
  }
}
