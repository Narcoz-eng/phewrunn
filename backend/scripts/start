#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

# Load shared environment setup
source "$(dirname "$0")/env.sh"

# Detect SQLite file DBs so we can keep local/legacy behavior without assuming it.
IS_SQLITE=0
SQLITE_DB_PATH=""
if [[ "${DATABASE_URL:-}" == file:* ]]; then
  IS_SQLITE=1
  SQLITE_DB_PATH="${DATABASE_URL#file:}"
fi

# Backup SQLite databases before proceeding (legacy/local only).
if [[ "${ENVIRONMENT}" == "production" ]] && [[ "${IS_SQLITE}" == "1" ]] && [[ -f "${SQLITE_DB_PATH}" ]]; then
  DATABASE_BACKUP_FILE="${SQLITE_DB_PATH}-$(date +%s)"
  echo "VACUUM INTO '${DATABASE_BACKUP_FILE}'" | sqlite3 "${SQLITE_DB_PATH}"
fi
 

# Install dependencies
echo "Installing dependencies..."
bun install

# Generate Prisma client and push schema if prisma is installed (database-auth skill)
if [[ -f "prisma/schema.prisma" ]]; then
  echo "Generating Prisma client..."
  bunx prisma generate
  if [[ "${ENVIRONMENT}" == "production" ]]; then
    if compgen -G "prisma/migrations/*/migration.sql" > /dev/null; then
      echo "Applying Prisma migrations..."
      bunx prisma migrate deploy
    else
      echo "No Prisma migrations found; pushing schema to database..."
      bunx prisma db push
    fi
  else
    echo "Pushing schema to database..."
    bunx prisma db push
  fi

  # Enable DB viewer (idempotent, safe to call multiple times)
  if [[ -n "${VIBECODE_PROJECT_ID:-}" ]]; then
    echo "Enabling database viewer..."
    curl -s -X POST "https://api.vibecodeapp.com/api/projects/${VIBECODE_PROJECT_ID}/cloud/db/enable" || true
  fi
fi

# Start server based on environment
# Use bun directly (not "bun run") so signals propagate correctly
if [[ "${ENVIRONMENT}" == "production" ]]; then
  echo "Starting server in production mode..."
  exec bun src/index.ts
else
  echo "Starting server in dev mode with hot reload..."
  exec bun --hot src/index.ts
fi
