# Frontend Environment Variables
# Copy this file to `.env.local` for local development.
# Do not commit a production/preview `VITE_BACKEND_URL` in `webapp/.env` because
# Vite loads `.env` in every mode (including production builds).

# Backend API URL (optional for local dev only)
# Leave unset in production builds so the app uses same-origin requests.
# Example local value: http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

# Optional: websocket realtime transport.
# Enable only when the backend is deployed on Bun and can serve /api/realtime/ws.
# Default behavior is disabled outside local development.
# VITE_REALTIME_ENABLED=true

# Privy App ID (required)
# Get this from your Privy dashboard: https://dashboard.privy.io
VITE_PRIVY_APP_ID=your-privy-app-id-here
